# Finance Data Download - API Keys
# Copy this file to .env and fill in your keys

# FRED (free - https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=

# EODHD (free tier available - https://eodhd.com/)
EODHD_API_KEY=

# Databento (paid with $125 free credits - https://databento.com/)
DATABENTO_API_KEY=

# Alpha Vantage (free tier - https://www.alphavantage.co/support/#api-key)
ALPHAVANTAGE_API_KEY=

# Finnhub (free tier - https://finnhub.io/)
FINNHUB_API_KEY=

# SEC EDGAR (no key needed, but set your identity for User-Agent)
SEC_EDGAR_USER_AGENT=YourName your@email.com
